# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
APP_URL=https://your-replit-url.repl.co

# ─── Anthropic / Claude AI ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Twilio (phone calls) ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Set to true in production to verify every webhook request is genuinely from Twilio
TWILIO_VALIDATE=false

# ─── Email – Option A: Generic SMTP (SendGrid, Mailgun, etc.) ─────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxxxxxxxx

# ─── Email – Option B: Gmail (comment out Option A above) ────────────────────
# GMAIL_USER=your_email@gmail.com
# GMAIL_APP_PASSWORD=your_16_char_app_password

# ─── Email recipients ─────────────────────────────────────────────────────────
EMAIL_FROM=receptionist@netcare.com
CLINIC_EMAIL=staff@netcare.com

# ─── Admin Dashboard ──────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=NetCare2024!

# ─── Tebra EHR Integration (future – leave blank to disable) ─────────────────
# TEBRA_API_KEY=
# TEBRA_PRACTICE_NAME=
# TEBRA_USERNAME=
# TEBRA_PASSWORD=
# TEBRA_DEFAULT_APPT_TYPE=
